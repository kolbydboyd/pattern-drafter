{
  "trailingSlash": false,
  "functions": {
    "api/generate-pattern.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/regenerate-pattern.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "memory": 256
    },
    "api/create-checkout.js": {
      "memory": 256
    },
    "api/send-email.js": {
      "memory": 256
    },
    "api/session-info.js": {
      "memory": 256
    },
    "api/join-list.js": {
      "memory": 256
    },
    "api/validate-code.js": {
      "memory": 256
    },
    "api/redeem-code.js": {
      "memory": 256
    }
  },
  "redirects": [
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/patterns.html", "destination": "/patterns", "statusCode": 301 },
    { "source": "/learn.html", "destination": "/learn", "statusCode": 301 },
    { "source": "/faq.html", "destination": "/faq", "statusCode": 301 },
    { "source": "/pricing.html", "destination": "/pricing", "statusCode": 301 },
    { "source": "/about.html", "destination": "/about", "statusCode": 301 },
    { "source": "/terms.html", "destination": "/terms", "statusCode": 301 },
    { "source": "/privacy.html", "destination": "/privacy", "statusCode": 301 },
    { "source": "/tester.html", "destination": "/tester", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/404", "destination": "/404.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/patterns", "destination": "/patterns.html" },
    { "source": "/patterns/:garment", "destination": "/patterns.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/learn", "destination": "/learn.html" },
    { "source": "/learn/:slug", "destination": "/learn.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/redeem", "destination": "/redeem.html" },
    { "source": "/tester", "destination": "/tester.html" }
  ],
  "crons": [
    { "path": "/api/cron-emails", "schedule": "0 9 * * *" },
    { "path": "/api/cron-pinterest", "schedule": "0 14,16,18,19,0,1,2 * * *" },
    { "path": "/api/cron-sitemap", "schedule": "0 6 * * *" },
    { "path": "/api/cron-images", "schedule": "0 7 * * *" },
    { "path": "/api/cron-links", "schedule": "30 7 * * *" }
  ]
}
