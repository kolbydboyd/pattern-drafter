# Cloudflare Pages serves shell.html at BOTH /shell AND /shell.html.
# These 301s remove the .html duplicates so Google only sees the clean URL.
# /patterns/* and /learn/* are NOT listed — all garment and article pages are
# pre-rendered as dist/patterns/*/index.html and dist/learn/*/index.html so
# Cloudflare serves them directly from the file tree without any redirect.
/index.html / 301
/about.html /about 301
/faq.html /faq 301
/pricing.html /pricing 301
/learn.html /learn 301
/patterns.html /patterns 301
/terms.html /terms 301
/privacy.html /privacy 301
/tester.html /tester 301
/checkout.html /checkout 301
/success.html /success 301
/affiliate.html /affiliate 301

# SEO landing pages have dedicated pre-rendered files at
# dist/{slug}/index.html with their own canonical URLs.
# No redirect rules needed — Cloudflare serves the static files directly.
